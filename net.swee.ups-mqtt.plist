<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>net.swee.ups-mqtt</string>
    <key>ProgramArguments</key>
    <array>
        <string>HOME_DIR/Applications/ups-mqtt.app/Contents/MacOS/ups-mqtt</string>
        <string>--config</string>
        <string>/etc/ups-mqtt/config.toml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>HOME_DIR/Library/Logs/ups-mqtt.log</string>
    <key>StandardErrorPath</key>
    <string>HOME_DIR/Library/Logs/ups-mqtt.log</string>
</dict>
</plist>
